import re
import torch
from transformers import AutoTokenizer, AutoModelForSequenceClassification, pipeline
# soynlp가 설치되어 있다면 repeat_normalize도 가져옵니다.
from soynlp.normalizer import repeat_normalize 
from fastapi import FastAPI
from pydantic import BaseModel

app = FastAPI()

def clean_text(text):
    # 특수문자 제거
    text = re.sub(r'[^가-힣0-9a-zA-Z\s]', '', str(text))
    # 반복되는 글자 정제 (예: ㅎㅎㅎㅎ -> ㅎㅎ)
    text = repeat_normalize(text, num_repeats=2)
    return text.strip()

model_path = "./my_review_model"
tokenizer = AutoTokenizer.from_pretrained(model_path)
model = AutoModelForSequenceClassification.from_pretrained(model_path)
classifier = pipeline("text-classification", model=model, tokenizer=tokenizer)

def predict_review(text):
    # 위에서 정의한 clean_text 함수를 여기서 사용합니다.
    clean_txt = clean_text(text) 
    result = classifier(clean_txt)
    
    label = result[0]['label']
    score = result[0]['score']
    
    sentiment = "긍정" if label == "LABEL_1" else "부정"

    print("리뷰: {text}")
    print("결과: {sentiment} (신뢰도: {score:.2f})")
    print("-" * 30)

    return sentiment, score

class ReviewInput(BaseModel):
    review_text: str

@app.post("/api/v1/reviews/analyze")
def analyze_review(data: ReviewInput):
    #프론트엔드가 보낸 리뷰 원문 꺼내기
    user_review = data.review_text 

    #AI 실행해서 결과 받아오기 (sentiment, score)
    ai_result, ai_score = predict_review(user_review)

    return {
        "succeed": True,
        "result": ai_result,
        "score": ai_score
        }
